---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/header.astro";
import Image from "astro/components/Image.astro";

import tvIpsum from "../../assets/tv-ipsum.png";
---

<Layout title="Tools" activeLink="Tools">
    <Header
        title="Tools"
        subtitle="Funny little things that may or may not be useful"
    />
    
    <div class="w-full mt-4">
        <a href={`/tools/tv-ipsum`} class="sm:h-[150px] sm:min-h-[150px] sm:max-h-[150px] p-2 rounded-lg transition duration-100 flex flex-col sm:flex-row theme-grayscale grayscale hover:grayscale-0 hover:bg-theme-card-hover blog-card-90s">
            <figure class="flex w-full sm:w-1/2 items-center justify-center h-[150px] sm:h-full">
                <Image
                    src={tvIpsum}
                    alt="A screenshot of the TV Lorem Ipsum tool"
                    width={550}
                    class="max-h-full max-w-full rounded-lg object-cover"
                    loading="eager"
                />
            </figure>
            <div
                class="flex flex-col justify-center items-end pt-2 sm:py-4 pl-0 sm:pl-4 w-full sm:w-1/2"
            >
            <h3 class="text-2xl sm:text-2xl font-bold text-right">
                TV Lorem Ipsum Generator
            </h3>
            <p class="text-right">
                Filler Text From Your Favorite Shows
            </p>
            </div>
        </a>
    </div>

    <div class="w-full mt-4">
        <a href={`/tools/doom`} class="sm:h-[150px] sm:min-h-[150px] sm:max-h-[150px] p-2 rounded-lg transition duration-100 flex flex-col sm:flex-row theme-grayscale grayscale hover:grayscale-0 hover:bg-theme-card-hover blog-card-90s">
            <figure class="flex w-full sm:w-1/2 items-center justify-center h-[150px] sm:h-full bg-black rounded-lg overflow-hidden relative">
                <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 60%, #3b0000 0%, #000 70%);"></div>
                <span style="position:relative;z-index:1;font-family:'Courier New',monospace;font-size:2.5rem;font-weight:900;letter-spacing:0.15em;color:#c0392b;text-shadow:0 0 20px #e74c3c,0 0 40px #c0392b;">DOOM</span>
            </figure>
            <div
                class="flex flex-col justify-center items-end pt-2 sm:py-4 pl-0 sm:pl-4 w-full sm:w-1/2"
            >
            <h3 class="text-2xl sm:text-2xl font-bold text-right">
                DOOM (1993)
            </h3>
            <p class="text-right">
                The classic id Software FPS, running in your browser via DOSBox WebAssembly
            </p>
            </div>
        </a>
    </div>
</Layout>